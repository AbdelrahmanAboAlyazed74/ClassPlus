# NAIB Backend — Environment Variables Template
DATABASE_URL=postgresql://root:password@localhost:5432/naib
REDIS_URL=redis://localhost:6379

JWT_SECRET=your-secret-key-here

# Paymob (replace with your keys)
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret
PAYMOB_PROFILE_ID=your_profile_id

# Fawry
FAWRY_MERCHANT_CODE=your_fawry_merchant
FAWRY_SECURITY_KEY=your_fawry_security_key

# InstaPay
INSTAPAY_API_KEY=your_instapay_key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
